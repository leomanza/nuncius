# Public values — checked into git as a template.
# Copy to .env (gitignored) and fill in / adjust as needed.

# ─── 0G Galileo testnet ─────────────────────────────────────────────
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602
DEPLOYER_ADDRESS=0xYourDeployerAddressHere

# Already-deployed Nuncius contracts (Galileo). Reuse these or redeploy.
POSEIDON_T3_ADDRESS=0xBa04c3B5A5Ba984A0E3DFA359b5F90566c313A1e
SEMAPHORE_VERIFIER_ADDRESS=0xCa5dbA14bBB19a72F4A36c088c1d437d8C0Cb3E1
SEMAPHORE_ADDRESS=0x3a546a753621100c7A569555FA2F081A3D761410
DISPUTE_DAO_ADDRESS=0x650c074910bC5855f6573f9d62EE5b8bA90664D9
DISPUTE_DAO_GROUP_ID=1

# ─── 0G Compute (deliberation) ──────────────────────────────────────
# Verify with `listService()` before each session — providers rotate.
ZG_COMPUTE_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# ─── 0G Storage / KV (agent working memory) ─────────────────────────
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# ─── Frontend (read by Next.js) ─────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_DISPUTE_DAO_ADDRESS=0x650c074910bC5855f6573f9d62EE5b8bA90664D9
