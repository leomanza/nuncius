# Secret values — never check into git. Copy to .env.secrets and fill in.
# .env.secrets is gitignored at repo root.

# ─── Deployer / coordinator ────────────────────────────────────────
# Funded with ~0.5 OG on Galileo (faucet: https://faucet.0g.ai).
# Used for: deploying contracts, registering voter commitments,
# opening proposals, paying gas on cleanup ops.
PRIVATE_KEY=0x...

# ─── Per-agent wallets ─────────────────────────────────────────────
# Each agent signs its own anonymous vote tx — NOT the deployer —
# so the on-chain tx graph cannot link agent identity → vote.
# `setup-agent-wallets.ts` generates and funds these idempotently.
#
# `*_SEMAPHORE_SECRET` is the seed that derives the Identity
# (commitment + Baby Jubjub pubkey). Changing it changes the
# commitment registered in the DAO group — keep it stable.

AGENT_1_PRIVATE_KEY=0x...
AGENT_1_ADDRESS=0x...
AGENT_1_SEMAPHORE_SECRET=zkswarm-e2e-agent-1
AGENT_1_BABYJUBJUB_PUBKEY=0x...
AGENT_1_COMMITMENT=...

AGENT_2_PRIVATE_KEY=0x...
AGENT_2_ADDRESS=0x...
AGENT_2_SEMAPHORE_SECRET=zkswarm-e2e-agent-2
AGENT_2_BABYJUBJUB_PUBKEY=0x...
AGENT_2_COMMITMENT=...

AGENT_3_PRIVATE_KEY=0x...
AGENT_3_ADDRESS=0x...
AGENT_3_SEMAPHORE_SECRET=zkswarm-e2e-agent-3
AGENT_3_BABYJUBJUB_PUBKEY=0x...
AGENT_3_COMMITMENT=...

AGENT_4_PRIVATE_KEY=0x...
AGENT_4_ADDRESS=0x...
AGENT_4_SEMAPHORE_SECRET=zkswarm-e2e-agent-4
AGENT_4_BABYJUBJUB_PUBKEY=0x...
AGENT_4_COMMITMENT=...

AGENT_5_PRIVATE_KEY=0x...
AGENT_5_ADDRESS=0x...
AGENT_5_SEMAPHORE_SECRET=zkswarm-e2e-agent-5
AGENT_5_BABYJUBJUB_PUBKEY=0x...
AGENT_5_COMMITMENT=...
